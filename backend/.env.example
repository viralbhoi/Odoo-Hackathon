# TransitOps Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# ⚠️  NEVER commit .env to git — only .env.example

# ─── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require"

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret

# ─── Google OAuth (optional) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
