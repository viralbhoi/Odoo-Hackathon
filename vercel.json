{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "cd frontend && pnpm run build",
  "outputDirectory": "frontend/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://transitops-abwv.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
