{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "bundler",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "paths": {
      "@/*": ["./src/*"],
      "@config/*": ["./src/common/config/*"],
      "@middleware/*": ["./src/common/middleware/*"],
      "@utils/*": ["./src/common/utils/*"],
      "@errors/*": ["./src/common/errors/*"],
      "@modules/*": ["./src/modules/*"]
    }
  },

  "include": ["src"],

  "exclude": [
    "node_modules",
    "dist",
    "src/seed.ts",
    "src/lib",
    "src/middlewares",
    "src/routes/auth.ts",
    "src/routes/dashboard.ts",
    "src/routes/docs.ts",
    "src/routes/drivers.ts",
    "src/routes/fuel-expenses.ts",
    "src/routes/health.ts",
    "src/routes/maintenance.ts",
    "src/routes/reports.ts",
    "src/routes/trips.ts",
    "src/routes/vehicles.ts"
  ]
}

